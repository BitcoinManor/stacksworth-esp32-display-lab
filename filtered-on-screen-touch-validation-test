#include <SPI.h>
#include <XPT2046_Touchscreen.h>
#include <TFT_eSPI.h>

#define T_CS 21
#define T_IRQ 22

XPT2046_Touchscreen ts(T_CS, T_IRQ);
TFT_eSPI tft = TFT_eSPI();

bool pressed = false;
unsigned long lastTouchMs = 0;

bool isGarbage(TS_Point p) {
  if (p.x <= 10 || p.x >= 4085) return true;
  if (p.y <= 10 || p.y >= 4085) return true;
  if (p.z <= 150 || p.z >= 4000) return true;
  return false;
}

void drawScreen(bool active) {
  tft.fillScreen(TFT_BLACK);

  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(3);
  tft.setCursor(95, 110);
  tft.println("READY");

  tft.setTextSize(2);
  tft.setCursor(78, 160);
  tft.println("TOUCH TEST");

  uint16_t c1 = active ? TFT_GREEN : TFT_ORANGE;
  uint16_t c2 = active ? TFT_WHITE : TFT_CYAN;

  tft.fillRoundRect(25, 250, 270, 90, 14, TFT_BLACK);
  tft.drawRoundRect(25, 250, 270, 90, 14, c1);
  tft.drawRoundRect(27, 252, 266, 86, 14, c2);

  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(3);
  tft.setCursor(65, 268);
  tft.println(active ? "TOUCH OK" : "TAP HERE");

  tft.setTextSize(2);
  tft.setCursor(92, 305);
  tft.println(active ? "VALID READ" : "TO TEST");
}

void setup() {
  Serial.begin(115200);

  ts.begin();
  ts.setRotation(2);

  tft.init();
  tft.setRotation(2);
  tft.invertDisplay(false);

  drawScreen(false);

  Serial.println("Filtered touch screen test ready...");
}

void loop() {
  bool validTouch = false;

  if (ts.touched()) {
    TS_Point p = ts.getPoint();

    if (!isGarbage(p)) {
      validTouch = true;
      lastTouchMs = millis();

      Serial.print("VALID X: ");
      Serial.print(p.x);
      Serial.print(" | Y: ");
      Serial.print(p.y);
      Serial.print(" | Z: ");
      Serial.println(p.z);

      if (!pressed) {
        pressed = true;
        drawScreen(true);
      }
    }
  }

  if (pressed && millis() - lastTouchMs > 300) {
    pressed = false;
    drawScreen(false);
  }

  delay(80);
}
